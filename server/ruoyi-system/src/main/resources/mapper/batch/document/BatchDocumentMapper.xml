<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.batch.document.mapper.BatchDocumentMapper">

    <resultMap type="com.ruoyi.batch.document.domain.BatchDocument" id="BatchDocumentResult">
        <id     property="documentId"     column="document_id"     />
        <result property="documentTitle"  column="document_title"  />
        <result property="documentType"   column="document_type"   />
        <result property="applyPages"     column="apply_pages"     />
        <result property="content"        column="content"         />
        <result property="sortWeight"     column="sort_weight"     />
        <result property="status"         column="status"          />
        <result property="isSystem"       column="is_system"       />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectBatchDocumentVo">
        select document_id, document_title, document_type, apply_pages, content, sort_weight, status, is_system,
               create_by, create_time, update_by, update_time, remark
        from batch_document
    </sql>

    <select id="selectBatchDocumentById" parameterType="Long" resultMap="BatchDocumentResult">
        <include refid="selectBatchDocumentVo"/>
        where document_id = #{documentId}
    </select>

    <select id="selectBatchDocumentList" parameterType="com.ruoyi.batch.document.domain.BatchDocument" resultMap="BatchDocumentResult">
        <include refid="selectBatchDocumentVo"/>
        <where>
            del_flag = 0
            <if test="documentTitle != null and documentTitle != ''">
                and document_title like concat('%', #{documentTitle}, '%')
            </if>
            <if test="documentType != null">
                and document_type = #{documentType}
            </if>
            <if test="applyPages != null and applyPages != ''">
                and find_in_set(#{applyPages}, apply_pages)
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by document_type asc, sort_weight desc, update_time desc
    </select>

    <select id="selectEnabledByTypeAndPage" parameterType="com.ruoyi.batch.document.domain.BatchDocument" resultMap="BatchDocumentResult">
        <include refid="selectBatchDocumentVo"/>
        <where>
            del_flag = 0
            and status = 0
            <if test="documentId != null">
                and document_id != #{documentId}
            </if>
            <if test="documentType != null">
                and document_type = #{documentType}
            </if>
            <if test="applyPages != null and applyPages != ''">
                and find_in_set(#{applyPages}, apply_pages)
            </if>
        </where>
    </select>

    <insert id="insertBatchDocument" parameterType="com.ruoyi.batch.document.domain.BatchDocument" useGeneratedKeys="true" keyProperty="documentId">
        insert into batch_document
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="documentTitle != null and documentTitle != ''">document_title,</if>
            <if test="documentType != null">document_type,</if>
            <if test="applyPages != null and applyPages != ''">apply_pages,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="sortWeight != null">sort_weight,</if>
            <if test="status != null">status,</if>
            <if test="isSystem != null">is_system,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="documentTitle != null and documentTitle != ''">#{documentTitle},</if>
            <if test="documentType != null">#{documentType},</if>
            <if test="applyPages != null and applyPages != ''">#{applyPages},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="sortWeight != null">#{sortWeight},</if>
            <if test="status != null">#{status},</if>
            <if test="isSystem != null">#{isSystem},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateBatchDocument" parameterType="com.ruoyi.batch.document.domain.BatchDocument">
        update batch_document
        <trim prefix="SET" suffixOverrides=",">
            <if test="documentTitle != null and documentTitle != ''">document_title = #{documentTitle},</if>
            <if test="documentType != null">document_type = #{documentType},</if>
            <if test="applyPages != null">apply_pages = #{applyPages},</if>
            <if test="content != null">content = #{content},</if>
            <if test="sortWeight != null">sort_weight = #{sortWeight},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isSystem != null">is_system = #{isSystem},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where document_id = #{documentId}
    </update>

    <update id="deleteBatchDocumentById" parameterType="Long">
        update batch_document set del_flag = 2 where document_id = #{documentId}
    </update>

    <update id="deleteBatchDocumentByIds">
        update batch_document set del_flag = 2 where document_id in
        <foreach collection="array" item="documentId" open="(" separator="," close=")">
            #{documentId}
        </foreach>
    </update>

</mapper>
