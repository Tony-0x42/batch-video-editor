<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.batch.home.mapper.BatchHomeBannerMapper">

    <resultMap type="com.ruoyi.batch.home.domain.BatchHomeBanner" id="BatchHomeBannerResult">
        <id     property="bannerId"    column="banner_id"    />
        <result property="title"       column="title"        />
        <result property="imageUrl"    column="image_url"    />
        <result property="linkUrl"     column="link_url"     />
        <result property="sortWeight"  column="sort_weight"  />
        <result property="status"      column="status"       />
        <result property="delFlag"     column="del_flag"     />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectBatchHomeBannerVo">
        select banner_id, title, image_url, link_url, sort_weight, status, del_flag, create_by, create_time, update_by, update_time, remark
        from batch_home_banner
    </sql>

    <select id="selectBatchHomeBannerList" parameterType="com.ruoyi.batch.home.domain.BatchHomeBanner" resultMap="BatchHomeBannerResult">
        <include refid="selectBatchHomeBannerVo"/>
        where del_flag = '0'
        <if test="title != null and title != ''"> and title like concat('%', #{title}, '%') </if>
        <if test="status != null and status != ''"> and status = #{status} </if>
        order by sort_weight asc, create_time desc
    </select>

    <select id="selectBatchHomeBannerById" parameterType="Long" resultMap="BatchHomeBannerResult">
        <include refid="selectBatchHomeBannerVo"/>
        where banner_id = #{bannerId} and del_flag = '0'
    </select>

    <insert id="insertBatchHomeBanner" parameterType="com.ruoyi.batch.home.domain.BatchHomeBanner" useGeneratedKeys="true" keyProperty="bannerId">
        insert into batch_home_banner
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="linkUrl != null">link_url,</if>
            <if test="sortWeight != null">sort_weight,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="linkUrl != null">#{linkUrl},</if>
            <if test="sortWeight != null">#{sortWeight},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateBatchHomeBanner" parameterType="com.ruoyi.batch.home.domain.BatchHomeBanner">
        update batch_home_banner
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="linkUrl != null">link_url = #{linkUrl},</if>
            <if test="sortWeight != null">sort_weight = #{sortWeight},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where banner_id = #{bannerId}
    </update>

    <update id="deleteBatchHomeBannerByIds">
        update batch_home_banner set del_flag = '2' where banner_id in
        <foreach collection="array" item="bannerId" open="(" separator="," close=")">
            #{bannerId}
        </foreach>
    </update>

</mapper>
